datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Team {
  id           String   @id @default(uuid())
  name         String   @unique
  shortName    String   // Represents code like IND, AUS, ENG
  logoUrl      String?
  homeMatches  Match[]  @relation("HomeTeam")
  awayMatches  Match[]  @relation("AwayTeam")
  createdAt    DateTime @default(now())
}

model Venue {
  id        String   @id @default(uuid())
  name      String   @unique
  city      String
  country   String
  latitude  Float
  longitude Float
  matches   Match[]
}

model Match {
  id            String       @id @default(uuid())
  apiFixtureId  String       @unique // Cross-reference with external API
  homeTeamId    String
  awayTeamId    String
  venueId       String
  scheduledAt   DateTime
  status        MatchStatus  @default(SCHEDULED)
  format        MatchFormat  // TEST, ODI, T20
  
  homeTeam      Team         @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team         @relation("AwayTeam", fields: [awayTeamId], references: [id])
  venue         Venue        @relation(fields: [venueId], references: [id])
  prediction    Prediction?

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([scheduledAt])
  @@index([status])
}

model Prediction {
  id                String   @id @default(uuid())
  matchId           String   @unique
  match             Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homeWinConfidence Float    // E.g., 0.65 for 65%
  awayWinConfidence Float    // E.g., 0.35 for 35%
  predictedWinnerId String
  calculatedAt      DateTime @default(now())
  featureSnapshot   Json     // Store the math snapshots (Form, H2H, Pitch factor) for audits
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum MatchFormat {
  TEST
  ODI
  T20
}
